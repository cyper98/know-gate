# ==========================================
# KnowGate MVP - Environment Variables
# ==========================================
# Copy to .env and fill required values.
# Required vars: see README quickstart.

# === General ===
KG_ENV=development
KG_LOG_LEVEL=INFO
KG_DOMAIN=localhost

# === Frontend (build-time) ===
# No default per dev rule; set to your API URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# === JWT (RS256) ===
# Generate via: make secrets
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# === Encryption (32 bytes, base64) ===
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
KG_ENCRYPTION_KEY=

# === PostgreSQL (atomic env vars per dev rules) ===
DB_HOST=postgres
DB_PORT=5432
DB_USER=knowgate
DB_PASSWORD=knowgate_dev_pwd
DB_NAME=knowgate

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# === Qdrant ===
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION=chunks

# === MinIO (S3-compatible) ===
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=knowgate
MINIO_ROOT_PASSWORD=knowgate_dev_pwd
MINIO_BUCKET=documents
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# === LLM (LiteLLM proxy) ===
LITELLM_HOST=litellm
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-dev-key
LITELLM_DEFAULT_MODEL=gpt-4o-mini
LITELLM_FALLBACK_MODEL=ollama/llama3

# === OpenAI (cloud LLM provider) ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# === Ollama (self-hosted LLM, optional fallback) ===
OLLAMA_BASE_URL=http://host.docker.internal:11434

# === Embedding (bge-m3 self-host) ===
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=8
EMBEDDING_CACHE_TTL=300

# === OAuth - Google ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile

# === OAuth - GitHub ===
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback
GITHUB_OAUTH_SCOPES=read:user user:email

# === SMTP (for magic link + invites) ===
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@knowgate.local
SMTP_TLS=false

# === Rate Limits ===
RATE_LIMIT_QUERY_PER_MINUTE=30
RATE_LIMIT_LOGIN_PER_15MIN=5

# === Search / Sync ===
SEARCH_TIMEOUT_SECONDS=10
SYNC_INTERVAL_MINUTES=5
SYNC_MAX_CONCURRENT=3
SYNC_BATCH_SIZE=100
MAX_DOC_SIZE_MB=50

# === Query ===
QUERY_MAX_LENGTH=2000
QUERY_SUMMARIZE_THRESHOLD=200
QUERY_TOP_K_VECTOR=20
QUERY_TOP_K_FINAL=5

# === Feedback / Retention ===
FEEDBACK_RETENTION_DAYS=90

# === Bootstrap Admin (created on first run if no users exist) ===
BOOTSTRAP_ADMIN_EMAIL=admin@knowgate.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_NAME=Admin
