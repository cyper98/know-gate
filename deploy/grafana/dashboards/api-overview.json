        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(kg_api_request_duration_seconds_bucket[5m])))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(kg_api_request_duration_seconds_bucket[5m])))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(kg_api_request_duration_seconds_bucket[5m])))", "legendFormat": "P99", "refId": "C" }
      ],
      "title": "API latency (P50 / P95 / P99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(kg_api_requests_total{status=~\"5..\"}[5m])) / sum(rate(kg_api_requests_total[5m]))",
          "legendFormat": "5xx rate",
          "refId": "A"
        }
      ],
      "title": "5xx error rate (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
