{
  "annotations": { "list": [] },
  "description": "PostgreSQL connection pool usage and slow-query counts for KnowGate.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 30 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "pg_stat_activity_max_conn",
          "legendFormat": "max",
          "refId": "B"
        }
      ],
      "title": "Postgres connection pool",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(increase(pg_stat_user_tables_seq_scan[5m]))",
          "legendFormat": "seq scan",
          "refId": "A"
        },
        {
          "expr": "sum(increase(pg_stat_user_tables_idx_scan[5m]))",
          "legendFormat": "index scan",
          "refId": "B"
        }
      ],
      "title": "Table scans (5m delta)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 7 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(pg_stat_statements_mean_exec_time_bucket[10m])))",
          "legendFormat": "P95 mean exec time",
          "refId": "A"
        }
      ],
      "title": "Query P95 mean execution time (pg_stat_statements)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["knowgate", "db"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "KnowGate / Database",
  "uid": "knowgate-db",
  "version": 1,
  "weekStart": ""
}
